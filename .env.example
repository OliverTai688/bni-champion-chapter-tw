# MongoDB connection used by Prisma.
# Use MongoDB Atlas for the first shared environment, or a local replica set if
# transactions are required during development.
DATABASE_URL="mongodb+srv://USER:PASSWORD@CLUSTER.mongodb.net/take-seat?retryWrites=true&w=majority"

# Auth.js / Google OAuth.
# Generate AUTH_SECRET with: npx auth secret
# Google redirect URI:
#   http://localhost:3000/api/auth/callback/google
AUTH_SECRET=""
AUTH_GOOGLE_ID=""
AUTH_GOOGLE_SECRET=""
AUTH_ALLOWED_EMAILS=""
AUTH_ALLOWED_DOMAIN=""

# Cloudflare R2 variables are reserved for the next storage batch.
R2_ACCOUNT_ID=""
R2_ACCESS_KEY_ID=""
R2_SECRET_ACCESS_KEY=""
R2_BUCKET_NAME=""
R2_PUBLIC_BASE_URL=""
R2_PRESIGNED_URL_TTL_SECONDS="900"
