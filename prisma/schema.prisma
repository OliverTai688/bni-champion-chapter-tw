// Prisma MongoDB foundation for take-seat.
// MongoDB support is pinned to Prisma ORM 6.19.x until official Prisma v7
// MongoDB support is available.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mongodb"
  url      = env("DATABASE_URL")
}

enum MeetingSessionStatus {
  draft
  scheduled
  live
  completed
  archived
  canceled
}

enum SeatMapStatus {
  draft
  published
  archived
}

enum SeatKind {
  host_team
  sound
  duty
  guest
  host
  member
  proxy
  empty
  reserved
}

enum SeatAssignmentStatus {
  assigned
  checked_in
  absent
  canceled
  released
  reserved
}

enum OperationActorRole {
  system
  admin
  staff
  member
  import
}

enum PublicEventStatus {
  draft
  preview
  published
  live
  completed
  archived
  hidden
}

enum LivePollType {
  single_choice
  multiple_choice
}

enum LivePollStatus {
  draft
  open
  closed
  archived
}

enum LivePollEligibility {
  public
  code_required
  signed_in_member
}

enum LivePollResultVisibility {
  hidden
  after_closed
  live_public
  admin_only
}

model MeetingSession {
  id           String               @id @default(auto()) @map("_id") @db.ObjectId
  weekId       String               @unique
  date         DateTime
  title        String
  chapterName  String
  meetingLabel String
  source       String               @default("seed")
  status       MeetingSessionStatus @default(draft)
  publicSlug   String?              @unique
  publicStatus PublicEventStatus    @default(draft)
  publicConfig Json?
  metadata     Json?
  createdAt    DateTime             @default(now())
  updatedAt    DateTime             @updatedAt

  seatMaps      SeatMap[]
  operationLogs OperationLog[]
  livePolls     LivePoll[]

  @@index([date])
  @@index([status])
  @@index([publicStatus])
}

model Member {
  id          String   @id @default(auto()) @map("_id") @db.ObjectId
  displayName String   @unique
  adminGroup  String?
  roles       String[]
  note        String?
  isActive    Boolean  @default(true)
  metadata    Json?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  assignments SeatAssignment[]
  pollOptions  LivePollOption[]

  @@index([isActive])
}

model SeatMap {
  id             String        @id @default(auto()) @map("_id") @db.ObjectId
  sessionId      String        @db.ObjectId
  session        MeetingSession @relation(fields: [sessionId], references: [id])
  title          String
  version        Int           @default(1)
  status         SeatMapStatus @default(draft)
  layoutKind     String        @default("bni-weekly-grid")
  topRoles       Json
  memberRoster   String[]
  heroes         String[]
  industryChains Json?
  source         String        @default("seed")
  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @updatedAt

  seats       Seat[]
  assignments SeatAssignment[]
  revisions   SeatMapRevision[]

  @@index([sessionId])
  @@index([status])
}

model SeatTemplate {
  id              String   @id @default(auto()) @map("_id") @db.ObjectId
  name            String   @unique
  description     String?
  layoutKind      String   @default("bni-weekly-grid")
  topRoles        Json
  items           Json
  memberRoster    String[]
  heroes          String[]
  industryChains  Json?
  sourceWeekId    String?
  sourceSeatMapId String?
  isActive        Boolean  @default(true)
  metadata        Json?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@index([isActive])
  @@index([sourceWeekId])
}

model Seat {
  id        String   @id @default(auto()) @map("_id") @db.ObjectId
  seatMapId String   @db.ObjectId
  seatMap   SeatMap  @relation(fields: [seatMapId], references: [id])
  seatKey   String
  row       Int?
  col       Int?
  zone      String   @default("main")
  position  Int
  kind      SeatKind @default(empty)
  label     String?
  capacity  Int      @default(1)
  metadata  Json?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  assignments SeatAssignment[]

  @@unique([seatMapId, seatKey])
  @@index([seatMapId, row, col])
  @@index([kind])
}

model SeatAssignment {
  id          String               @id @default(auto()) @map("_id") @db.ObjectId
  seatMapId   String               @db.ObjectId
  seatMap     SeatMap              @relation(fields: [seatMapId], references: [id])
  seatId      String               @db.ObjectId
  seat        Seat                 @relation(fields: [seatId], references: [id])
  memberId    String?              @db.ObjectId
  member      Member?              @relation(fields: [memberId], references: [id])
  displayName String
  role        String?
  guestNumber String?
  hostFor     String?
  status      SeatAssignmentStatus @default(assigned)
  headcount   Int                  @default(1)
  source      String               @default("seed")
  metadata    Json?
  createdAt   DateTime             @default(now())
  updatedAt   DateTime             @updatedAt

  @@index([seatMapId])
  @@index([seatId])
  @@index([memberId])
  @@index([status])
}

model SeatMapRevision {
  id                String   @id @default(auto()) @map("_id") @db.ObjectId
  seatMapId         String   @db.ObjectId
  seatMap           SeatMap  @relation(fields: [seatMapId], references: [id])
  version           Int
  snapshot          Json
  validationSummary Json?
  createdBy         String?
  reason            String?
  createdAt         DateTime @default(now())

  @@unique([seatMapId, version])
  @@index([seatMapId])
}

model OperationLog {
  id          String             @id @default(auto()) @map("_id") @db.ObjectId
  sessionId   String?            @db.ObjectId
  session     MeetingSession?    @relation(fields: [sessionId], references: [id])
  actorRole   OperationActorRole @default(system)
  actorName   String?
  action      String
  targetType  String
  targetId    String?
  reason      String?
  metadata    Json?
  createdAt   DateTime           @default(now())

  @@index([sessionId])
  @@index([action])
  @@index([targetType])
  @@index([createdAt])
}

model LivePoll {
  id               String                   @id @default(auto()) @map("_id") @db.ObjectId
  sessionId        String                   @db.ObjectId
  session          MeetingSession           @relation(fields: [sessionId], references: [id])
  title            String
  description      String?
  type             LivePollType             @default(single_choice)
  status           LivePollStatus           @default(draft)
  eligibility      LivePollEligibility      @default(code_required)
  resultVisibility LivePollResultVisibility @default(after_closed)
  voteCodeHash     String?
  opensAt          DateTime?
  closesAt         DateTime?
  metadata         Json?
  createdAt        DateTime                 @default(now())
  updatedAt        DateTime                 @updatedAt

  options LivePollOption[]
  votes   LivePollVote[]

  @@index([sessionId])
  @@index([status])
  @@index([eligibility])
}

model LivePollOption {
  id                String         @id @default(auto()) @map("_id") @db.ObjectId
  pollId            String         @db.ObjectId
  poll              LivePoll       @relation(fields: [pollId], references: [id])
  memberId          String?        @db.ObjectId
  member            Member?        @relation(fields: [memberId], references: [id])
  label             String
  publicDescription String?
  position          Int
  isActive          Boolean        @default(true)
  metadata          Json?
  createdAt         DateTime       @default(now())
  updatedAt         DateTime       @updatedAt

  votes LivePollVote[]

  @@index([pollId])
  @@index([memberId])
  @@index([isActive])
}

model LivePollVote {
  id                 String         @id @default(auto()) @map("_id") @db.ObjectId
  pollId             String         @db.ObjectId
  poll               LivePoll       @relation(fields: [pollId], references: [id])
  optionId           String         @db.ObjectId
  option             LivePollOption @relation(fields: [optionId], references: [id])
  tokenHash          String
  anonymousVoterHash String?
  metadata           Json?
  submittedAt        DateTime       @default(now())

  @@unique([pollId, tokenHash])
  @@index([pollId])
  @@index([optionId])
  @@index([submittedAt])
}

model Asset {
  id          String   @id @default(auto()) @map("_id") @db.ObjectId
  provider    String   @default("r2")
  bucket      String
  key         String
  contentType String
  byteSize    Int?
  checksum    String?
  visibility  String   @default("private")
  purpose     String
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@unique([bucket, key])
  @@index([purpose])
  @@index([visibility])
}
